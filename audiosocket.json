{
  "port": 9092,
  "transcription_mode": "on_close",
  "input_sample_rate": 8000,
  "input_channels": 1,
  "input_sample_width": 2,
  "use_silero_vad": false,
  "silero_vad_threshold": 0.5,
  "web_passcode": "",
  "vad_silence_threshold_ms": 5000,
  "vad_rms_threshold": 100,
  "vad_min_chunk_ms": 1000,
  "debug_mode": false,
  "ignore_silence_timeout": true,
  "send_silence_frames": true,
  "bind_address": "0.0.0.0",
  "max_concurrent_connections": 100,
  "force_endian_swap": true,
  "auto_restart_worker": true,
  "whisper_model": "turbo",
  "whisper_engine": "openai",
  "api_provider": "local",
  "api_base_url": "https://integrate.api.nvidia.com/v1",
  "api_key": "",
  "api_model_name": "nvidia/whisper-large-v3",
  "llm_model_name": "",
  "local_whisper_device": "auto",
  "local_whisper_compute_type": "default",
  "web_host": "0.0.0.0",
  "web_port": 8000,
  "ai_no_speech_threshold": 0.6,
  "ai_min_music_gap": 3,
  "silence_frame_ms": 20,
  "whisper": {
    "task": "transcribe",
    "temperature": 0,
    "no_speech_threshold": 0.6,
    "logprob_threshold": -1,
    "compression_ratio_threshold": 2.4,
    "condition_on_previous_text": true,
    "initial_prompt": "",
    "beam_size": 5,
    "best_of": 5,
    "vad_filter": true,
    "language": ""
  },
  "delivery": {
    "enabled": false,
    "url": "http://your-server/api/receive-audio",
    "method": "POST",
    "field_name": "audio",
    "timeout_s": 10,
    "extra_fields": {
      "session_id": "{uuid}"
    }
  }
}